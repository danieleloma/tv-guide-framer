{
  "name": "tv-guide-framer",
  "version": "1.0.0",
  "description": "Excel to JSON TV Guide converter with Framer component",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node scripts/excel-to-json.ts",
    "convert": "ts-node scripts/excel-to-json.ts",
    "convert:sa": "ts-node scripts/sa-excel-to-json.ts --in \"$SA_EXCEL\" --out \"public/sa-region.json\"",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "keywords": [
    "excel",
    "json",
    "tv-guide",
    "framer",
    "typescript",
    "react"
  ],
  "author": "TV Guide Team",
  "license": "MIT",
  "dependencies": {
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
